{
  "name": "task-sentinel",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/desktop run dev",
    "build": "npm run build:packages && npm run build:desktop",
    "build:packages": "node ./node_modules/typescript/bin/tsc -b tsconfig.packages.json",
    "build:observer": "npm --prefix apps/observer-cli run build",
    "build:desktop": "npm --prefix apps/desktop run build",
    "lint": "npm --prefix apps/desktop run lint",
    "preview": "npm --prefix apps/desktop run preview",
    "typecheck": "npm --workspaces run typecheck",
    "predev:observer": "npm run build:observer",

    "dev:test": "tsx scripts/dev-test.ts",
    "dev:observer-cli": "tsx scripts/dev-observer-cli.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0"
  }
}
