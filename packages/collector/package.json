{
  "name": "@task-sentinel/collector",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -b tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "npm:install": "npm install --workspaces=false --install-links"
  },
  "dependencies": {
    "@task-sentinel/shared": "file:../shared"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "~6.0.2"
  }
}
